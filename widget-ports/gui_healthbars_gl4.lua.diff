-	newVAO:AttachVertexBuffer(newVBOTable.instanceVBO)
+	newVAO:AttachVertexBuffer(barCornerVBO)            -- per-vertex: 28 strip corners
+	newVAO:AttachInstanceBuffer(newVBOTable.instanceVBO) -- per-instance: one unit per instance
 	newVBOTable.VAO = newVAO
 	if usesFeatures then newVBOTable.featureIDs = true end
 	return newVBOTable
