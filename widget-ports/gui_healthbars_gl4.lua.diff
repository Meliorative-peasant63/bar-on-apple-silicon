+	-- BAR-on-mac: shared static 28-vertex corner-index buffer (TRIANGLE_STRIP). The
+	-- vertex shader expands each instanced unit into the bar using these indices. A real
+	-- per-vertex buffer must be bound — MoltenVK crashes on gl_VertexID-only draws.
+	if not barCornerVBO then
+		barCornerVBO = gl.GetVBO(GL.ARRAY_BUFFER, false)
+		barCornerVBO:Define(BAR_STRIP_VERTS, {{id = 5, name = 'v_vertIdx', size = 1}})
+		local idx = {}
+		for i = 0, BAR_STRIP_VERTS - 1 do idx[i + 1] = i end
+		barCornerVBO:Upload(idx)
+	end
 
